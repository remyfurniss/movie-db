generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  watchlists Watchlist[]
  ratings    Rating[]
}

model Movie {
	id          	String   @id @default(uuid())
  	tmdbId      	Int      @unique	
  	title       	String
  	overview 	String?
  	releaseDate 	Int?
  	runtime     	Int?
	homepage	String?
	imdbId		String?
	popularity	Float?
	posterPath 	String?
	backdropPath 	String?
	voteAverage	Float?
	voteCount 	Int?

	watched      Boolean  @default(false)

	genres      MovieGenre[]
  	rating     Rating[]
  	watchlists  WatchlistItem[]
	watchHistory	WatchHistory?


	createdAt DateTime @default(now())
        updatedAt DateTime @updatedAt

        @@index([title])
}

model Genre {
	id    	String @id @default(uuid())
	tmdbId  Int    @unique
  	name  	String @unique

  	movieGenres MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Rating {
  id        String @id @default(uuid())
  score     Int

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  movie     Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId]) // ✅ CRITICAL FIX
}

model Watchlist {
  id        String @id @default(uuid())
  name      String

  user      User   @relation(fields: [userId], references: [id])
  userId    String

  items     WatchlistItem[]

  createdAt DateTime @default(now())

  @@unique([userId, name]) // ✅ THIS is correct
}

model WatchlistItem {
  watchlistId String
  movieId     String

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([watchlistId, movieId]) // movie appears once per watchlist
}

model WatchHistory {
	id        	Int      	@id @default(autoincrement())
	movieId   	String		@unique
	watchedAt	DateTime	@default(now())

	movie 		Movie 		@relation(fields: [movieId], references: [id])
}