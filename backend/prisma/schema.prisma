generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)

  watchlists Watchlist[]
  ratings    Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Movie {
	id          	String   @id @default(uuid())
  	tmdbId      	Int      @unique	
  	title       	String
  	overview 	String?
  	releaseDate 	Int?
  	runtime     	Int?
	homepage	String?
	imdbId		String?
	popularity	Float?
	posterPath 	String?
	backdropPath 	String?
	voteAverage	Float?

  genres      MovieGenre[]
  ratings     Rating[]
  watchlists  WatchlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}

model Genre {
  id    String @id @default(uuid())
  name  String @unique

  movies MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Rating {
  id      String @id @default(uuid())
  score   Int

  userId  String
  movieId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, movieId])
}

model Watchlist {
  id      String @id @default(uuid())
  name    String

  userId  String
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  items     WatchlistItem[]

  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model WatchlistItem {
  watchlistId String
  movieId     String

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([watchlistId, movieId]) // movie appears once per watchlist
}