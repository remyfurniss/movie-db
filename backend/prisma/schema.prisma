generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
	id          	String   @id @default(uuid())
  	tmdbId      	Int      @unique	
  	title       	String
  	overview 	String?
  	releaseDate 	Int?
  	runtime     	Int?
	homepage	String?
	imdbId		String?
	popularity	Float?
	posterPath 	String?
	backdropPath 	String?
	voteAverage	Float?
	voteCount 	Int?

	watched      Boolean  @default(false)

	genres      MovieGenre[]
  	rating     Rating?
  	watchlists  WatchlistItem[]

	createdAt DateTime @default(now())
        updatedAt DateTime @updatedAt

        @@index([title])
}

model Genre {
	id    	String @id @default(uuid())
	tmdbId  Int    @unique
  	name  	String @unique

  	movieGenres MovieGenre[]
}

model MovieGenre {
  movieId String
  genreId String

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
}

model Rating {
  id      String @id @default(uuid())
  score   Int

  movieId String @unique
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Watchlist {
  id      String @id @default(uuid())
  name    String

  items     WatchlistItem[]

  createdAt DateTime @default(now())

  @@unique([name])
}

model WatchlistItem {
  watchlistId String
  movieId     String

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie     Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([watchlistId, movieId]) // movie appears once per watchlist
}